
# Contract Intelligence Platform — Environment Configuration
# Copy this file to .env and adjust values for your hardware.

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── Qdrant ──
QDRANT_URL=http://localhost:6333

# ── Ollama (LLM) ──
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TEMPERATURE=0.0
OLLAMA_MAX_TOKENS=1024
OLLAMA_TIMEOUT=120
OLLAMA_SEED=42

# Context window — adjust based on your GPU VRAM:
#   GPU 4GB  → 4096
#   GPU 6GB  → 8192
#   GPU 8GB  → 16384  (default, recommended)
#   GPU 12GB+ → 32768
#   CPU-only  → 4096  (slow but works)
OLLAMA_NUM_CTX=16384

# ── Embedding Model ──
EMBEDDING_MODEL=all-MiniLM-L6-v2
# Run embeddings on "cpu", "cuda", or "auto"
# For low-spec/mid-spec systems, "cpu" is highly recommended as all-MiniLM-L6-v2
# is very small/fast and running it on CPU saves GPU VRAM for Ollama/PaddleOCR.
EMBEDDING_DEVICE=cpu

# ── OCR Engine (PaddleOCR) ──
# Set to false to force CPU-only execution (useful for low-spec/non-GPU machines):
OCR_USE_GPU=true
OCR_GPU_ID=0
OCR_GPU_MEM=500
# CPU thread count (lower to 2 or 4 to avoid saturating low-spec CPU cores)
OCR_CPU_THREADS=4
# Enable Intel MKL-DNN CPU acceleration (set to false if CPU is not Intel/AMD x86)
OCR_ENABLE_MKLDNN=true
# DPI resolution to render PDF pages (use 150 or 200 for low-spec CPU to speed up OCR 2x, 300 for high quality)
OCR_DPI=300

# ── Chunking ──
# Larger chunks reduce clause fragmentation but use more memory.
CHUNK_MAX_CHARS=1200
CHUNK_OVERLAP=200

# ── Retrieval ──
# How many chunks to fetch per question. More = better recall, slower.
SEARCH_TOP_K=15
# Max chars fed to LLM. Must fit within OLLAMA_NUM_CTX (~1 token ≈ 4 chars).
MAX_CONTEXT_CHARS=12000
# How many leading document chunks to fetch for preamble (Parties, Dates).
PREAMBLE_CHUNKS=10

# ── Upload ──
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=data/uploads

# ── App ──
DEBUG=false
